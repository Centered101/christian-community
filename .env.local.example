# Supabase project — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...           # "anon" "public" key
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # "service_role" "secret" key — server-only, never expose to the client

# Admin login (used until you change it from /admin/settings, then it's stored in the database instead)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme1234
ADMIN_SECRET=any-long-random-string             # signs the admin session cookie

# Optional — shown in the admin sidebar
NEXT_PUBLIC_ADMIN_DISPLAY=Admin
