# Supabase project — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Never expose this in client code and never commit real values.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Fallback admin login.
# Always accepted alongside stored credentials from Supabase admin_settings.
ADMIN_FALLBACK_USERNAME=admin
ADMIN_FALLBACK_PASSWORD=change-this-password

# Signs the admin session cookie. Use a long random string.
ADMIN_SECRET=use-a-long-random-secret

# Optional — shown in the admin sidebar
NEXT_PUBLIC_ADMIN_DISPLAY=Admin
